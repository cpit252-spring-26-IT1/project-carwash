<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:padding="24dp"
        android:background="#F8F9FA"
        tools:context=".activities.StaffManagementActivity">

    <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="25dp">

        <TextView
                android:id="@+id/tvBackStaff"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Back"
                android:textColor="#3498DB"
                android:textStyle="bold"
                android:textSize="16sp" />

    </LinearLayout>

    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Manage Staff"
            android:textSize="28sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:layout_gravity="center"
            android:layout_marginBottom="8dp" />

    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Add and remove cashier accounts"
            android:textSize="16sp"
            android:textColor="#7F8C8D"
            android:layout_gravity="center"
            android:layout_marginBottom="35dp" />

    <Button
            android:id="@+id/btnAddCashier"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:text="+ Add New Cashier"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:backgroundTint="#27AE60"
            android:layout_marginBottom="30dp"
            app:cornerRadius="15dp"
            android:elevation="4dp" />

    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Cashiers"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="#2C3E50"
            android:layout_marginBottom="15dp" />

    <TextView
            android:id="@+id/tvEmptyStaff"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No cashiers found"
            android:textSize="16sp"
            android:textColor="#7F8C8D"
            android:gravity="center"
            android:visibility="gone"
            android:layout_marginTop="40dp" />

    <ListView
            android:id="@+id/listStaff"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:divider="@android:color/transparent"
            android:dividerHeight="15dp"
            android:cacheColorHint="@android:color/transparent"
            tools:listitem="@layout/item_cashier" />

</LinearLayout>